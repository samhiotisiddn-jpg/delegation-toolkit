# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service_role_jwt>

# ── KuCoin ──────────────────────────────────────────────────────────────────
KUCOIN_API_KEY=<key>
KUCOIN_API_SECRET=<secret>
KUCOIN_PASSPHRASE=<passphrase>

# ── xAI ─────────────────────────────────────────────────────────────────────
XAI_API_KEY=<xai_key>

# ── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Slack (comma-separated webhook URLs) ────────────────────────────────────
SLACK_WEBHOOK_URLS=https://hooks.slack.com/services/...,https://hooks.slack.com/services/...

# ── Make.com (comma-separated outbound webhook URLs) ────────────────────────
MAKE_WEBHOOK_URLS=https://hook.eu1.make.com/...,https://hook.eu1.make.com/...

# ── ngrok ───────────────────────────────────────────────────────────────────
NGROK_AUTHTOKEN=<ngrok_authtoken>

# ── Trading config ──────────────────────────────────────────────────────────
MIN_SPREAD_PCT=0.5
MAX_ORDER_USDT=50
DRY_RUN=true          # set to false for live trading
POLL_SECS=60

# ── Server ──────────────────────────────────────────────────────────────────
PORT=8080
