# ─────────────────────────────────────────────────────────────────────────────
# FractalMesh — Global Environment Variable Template
#
# Copy this file to global.env and fill in real values.
# Source it before starting the orchestrator:
#
#   set -a && source fractalmesh/shared/env/global.env && set +a
#   python fractalmesh/orchestrator/orchestrator.py
#
# Values in this file are NEVER read by the orchestrator directly.
# The orchestrator reads from the live environment of the process that
# launched it.  This file is documentation only.
# ─────────────────────────────────────────────────────────────────────────────

# ── nextupdate agent ─────────────────────────────────────────────────────────
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_BOT_TOKEN=
GITHUB_TOKEN=

# ── royce agent ──────────────────────────────────────────────────────────────
KUCOIN_API_KEY=
KUCOIN_API_SECRET=
KUCOIN_API_PASSPHRASE=
PIONEX_API_KEY=
PIONEX_API_SECRET=

# ── meshmax agent ────────────────────────────────────────────────────────────
METAMASK_PRIVATE_KEY=
ALCHEMY_API_URL=
ETH_ADDRESS=

# ── ultra / evolve / converge / local agents ─────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=

# ── converge agent ───────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
